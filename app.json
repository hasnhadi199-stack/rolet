{
  "expo": {
    "name": "Rolet",
    "slug": "rolet",
    "backgroundColor": "#1a1625",
    "splash": {
      "backgroundColor": "#1a1625"
    },
    "scheme": "rolet",
    "extra": {
      "eas": {
        "projectId": "483bb82a-0fb7-4c6a-8033-365103e54c18"
      }
    },
    "owner": "hasn299",
    "android": {
      "package": "com.hasn299.rolet",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": ["android.permission.RECORD_AUDIO", "android.permission.MODIFY_AUDIO_SETTINGS"]
    },
    "ios": {
      "bundleIdentifier": "com.hasn299.rolet",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "لسماع صوتك مباشرة في الدردشة الجماعية"
      }
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": ["./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf"]
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#a78bfa",
          "defaultChannel": "messages"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6295703745962080~6828641222",
          "iosAppId": "ca-app-pub-6295703745962080~6828641222"
        }
      ],
      "@livekit/react-native-expo-plugin",
      [
        "expo-media-library",
        {
          "photosPermission": "للوصول إلى الصور والموسيقى",
          "savePhotosPermission": "لحفظ الملفات",
          "granularPermissions": ["audio", "photo"]
        }
      ]
    ]
  }
}
